# =============================================
# ENVIRONMENT VARIABLES - LIBRARY MANAGEMENT SYSTEM
# =============================================

# Database Configuration
DB_HOST=mysql
DB_PORT=3306
DB_USER=root
DB_PASSWORD=rootpassword
DB_NAME=library_management_system

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production_123456789
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Server Configuration
NODE_ENV=production
FRONTEND_URL=http://localhost:3000
BACKEND_NODE_PORT=3001
BACKEND_SPRING_PORT=3002
FRONTEND_PORT=3000

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password
EMAIL_FROM=noreply@library-system.com

# File Upload Configuration
MAX_FILE_SIZE=5MB
UPLOAD_PATH=./uploads
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,pdf,doc,docx

# Security Configuration
BCRYPT_ROUNDS=12
SESSION_SECRET=your_session_secret_here
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Admin Configuration
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_EMAIL=admin@library-system.com

# Library Configuration
MAX_BORROW_DAYS=14
MAX_RESERVATION_DAYS=7
FINE_PER_DAY=5000
MAX_BOOKS_PER_USER=5

# Docker Configuration
DOCKER_NETWORK=library_network
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=library_management_system
